{
  "mcpServers": {
    "feishu": {
      "command": "bun",
      "args": [
        "run",
        "--cwd",
        "${CLAUDE_PLUGIN_ROOT}",
        "--shell=bun",
        "--silent",
        "start"
      ]
    },
    "lark": {
      "command": "sh",
      "args": [
        "-c",
        ". \"$HOME/.claude/channels/feishu/.env\" && exec npx -y @larksuiteoapi/lark-mcp mcp -a \"$FEISHU_APP_ID\" -s \"$FEISHU_APP_SECRET\" -d \"${FEISHU_DOMAIN:-feishu}\" --token-mode tenant_access_token -t preset.base.default,preset.base.batch,preset.doc.default,preset.calendar.default"
      ]
    }
  }
}